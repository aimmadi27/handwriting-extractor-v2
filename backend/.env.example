# ── LLM ──────────────────────────────────────────────────────────────────────
# Any LiteLLM-compatible model string
LLM_MODEL=gemini/gemini-2.0-flash

# Add the key matching your chosen provider — only one is required
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GROQ_API_KEY=your-groq-api-key
# NVIDIA_NIM_API_KEY=your-nvidia-api-key
# TOGETHERAI_API_KEY=your-together-api-key
# MISTRAL_API_KEY=your-mistral-api-key

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match an Authorised Redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-random-secret-here
# Access token lifetime (hours) — keep short since refresh tokens handle renewal
JWT_EXPIRY_HOURS=1
# Refresh token lifetime (days)
REFRESH_TOKEN_DAYS=7
# Set to "true" in production (requires HTTPS)
COOKIE_SECURE=false

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/handwriting

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# How long uploaded PDFs are kept in Redis (seconds). Default: 2 hours
UPLOAD_TTL_SECONDS=7200

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
MAX_PAGES=50

# ── Usage quota ───────────────────────────────────────────────────────────────
# Maximum pages a single user can extract per day (resets at midnight UTC)
MAX_PAGES_PER_DAY=100
