# LLM provider (any model supported by LiteLLM)
LLM_MODEL=gemini/gemini-2.0-flash

# LLM API keys — add the one matching your LLM_MODEL
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must be added to Google Cloud Console → Authorized redirect URIs
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-random-secret-here

# React dev server origin
FRONTEND_URL=http://localhost:5173
